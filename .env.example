# ==========================================
# EdTech Platform Environment Configuration
# ==========================================

# Application
NODE_ENV=development
APP_NAME=EdTech Platform
APP_URL=http://localhost:3000

# ==========================================
# Backend Configuration
# ==========================================

# Server
PORT=3001
API_URL=http://localhost:3001

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Direct Database Connection (for migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis Cache
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ==========================================
# Frontend Configuration
# ==========================================

# API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (Client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ==========================================
# External Services (Optional)
# ==========================================

# Payment Gateway
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret

# SMS Gateway
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=EDTECH

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ==========================================
# CORS / Security
# ==========================================

# Comma-separated list of allowed frontend origins (required in production)
# Example: https://myapp.railway.app,https://www.myinstitute.com
ALLOWED_ORIGINS=http://localhost:3000

# ==========================================
# Railway Deployment Variables
# ==========================================

# These are automatically set by Railway
# RAILWAY_STATIC_URL=your-app.railway.app
# RAILWAY_STATIC_DOMAIN=your-app.railway.app
# RAILWAY_PROJECT_NAME=edtech-platform